RUST_LOG=info,sqlx=warn,tower_http=info

SKILLHUB__SERVER__HOST=0.0.0.0
SKILLHUB__SERVER__PORT=8080
SKILLHUB__SERVER__PUBLIC_BASE_URL=http://localhost:8080

SKILLHUB__DATABASE__URL=postgres://skillhub:skillhub@localhost:5432/skillhub
SKILLHUB__DATABASE__MAX_CONNECTIONS=16

SKILLHUB__REDIS__URL=redis://localhost:6379

SKILLHUB__AUTH__JWT_SECRET=change-me-in-production
SKILLHUB__AUTH__BOOTSTRAP_ADMIN_ENABLED=true
SKILLHUB__AUTH__BOOTSTRAP_ADMIN_USERNAME=admin
SKILLHUB__AUTH__BOOTSTRAP_ADMIN_PASSWORD=ChangeMe!2026

# Dev only: accept X-Mock-User-Id header. MUST be false/absent in prod.
SKILLHUB__AUTH__ALLOW_MOCK_HEADER=true
